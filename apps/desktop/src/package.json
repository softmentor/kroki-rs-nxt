{
  "name": "@kroki/desktop-ui",
  "version": "0.1.0-alpha.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\" && tsc --noEmit -p tsconfig.json",
    "test": "node --test tests/**/*.test.js",
    "test:unit": "npm run test",
    "test:integration": "npm run test",
    "fmt:check": "echo \"@kroki/desktop-ui fmt:check baseline\"",
    "fmt:fix": "echo \"@kroki/desktop-ui fmt:fix baseline\""
  }
}
