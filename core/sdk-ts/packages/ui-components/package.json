{
  "name": "@kroki/ui-components",
  "version": "0.1.0-alpha.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "lit": "^3.2.1"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\" && tsc --noEmit -p tsconfig.json",
    "test": "node --test tests/*.test.js",
    "test:unit": "npm run test",
    "test:integration": "npm run test",
    "fmt:check": "echo \"@kroki/ui-components fmt:check baseline\"",
    "fmt:fix": "echo \"@kroki/ui-components fmt:fix baseline\""
  }
}
