{
  "name": "@kroki/ui-tokens",
  "version": "0.1.0-alpha.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./theme.css": "./src/theme.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && mkdir -p dist && cp src/theme.css dist/theme.css",
    "lint": "eslint \"src/**/*.ts\" && tsc --noEmit -p tsconfig.json",
    "test": "npm run build && node --test tests/*.test.js",
    "test:unit": "npm run test",
    "test:integration": "npm run test",
    "fmt:check": "echo \"@kroki/ui-tokens fmt:check baseline\"",
    "fmt:fix": "echo \"@kroki/ui-tokens fmt:fix baseline\""
  }
}
