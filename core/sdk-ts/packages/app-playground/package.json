{
  "name": "@kroki/app-playground",
  "version": "0.1.0-alpha.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@kroki/host-adapters": "workspace:*",
    "@kroki/runtime-wasm": "workspace:*",
    "@kroki/ui-components": "workspace:*",
    "@kroki/ui-tokens": "workspace:*",
    "lit": "^3.2.1"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\" && tsc --noEmit -p tsconfig.json",
    "test": "npm run build && node --test tests/*.test.js",
    "test:unit": "npm run test",
    "test:integration": "npm run test",
    "fmt:check": "echo \"@kroki/app-playground fmt:check baseline\"",
    "fmt:fix": "echo \"@kroki/app-playground fmt:fix baseline\""
  }
}
