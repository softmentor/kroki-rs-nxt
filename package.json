{
  "name": "kroki-rs-nxt",
  "version": "0.1.0-alpha.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "workspaces": [
    "core/sdk-ts",
    "apps/desktop/src",
    "apps/myst-plugin",
    "apps/vscode-ext",
    "apps/web-app",
    "shared/design-system"
  ],
  "scripts": {
